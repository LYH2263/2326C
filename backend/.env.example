NODE_ENV=development

PORT=8000
CORS_ORIGIN=*

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=lab_animal_db
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_CONNECTION_LIMIT=10

JWT_SECRET=
JWT_EXPIRES_IN=24h
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

PUBLIC_APP_TITLE=实验室动物信息管理系统
PUBLIC_ENABLE_REGISTRATION=false
PUBLIC_ENABLE_EXPERIMENTS=true
PUBLIC_ENABLE_HEALTH_RECORDS=true
PUBLIC_ENABLE_FEEDING_RECORDS=true
PUBLIC_MAINTENANCE_MODE=false
PUBLIC_ANNOUNCEMENT=
